---
interface Props {
  title: string;
}
const { title } = Astro.props;
const base = '/my-wiki';
---
<!DOCTYPE html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="個人知識倉儲系統" />
    <title>{title} | my-wiki</title>
    <style>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --bg: #ffffff;
        --text: #1a1a1a;
        --muted: #6b7280;
        --border: #e5e7eb;
        --accent: #3b82f6;
        --mark-bg: #fef08a;
        --code-bg: #f3f4f6;
        --nav-bg: #f9fafb;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #0f172a;
          --text: #e2e8f0;
          --muted: #94a3b8;
          --border: #1e293b;
          --accent: #60a5fa;
          --mark-bg: #854d0e;
          --code-bg: #1e293b;
          --nav-bg: #1e293b;
        }
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.7;
        font-size: 16px;
      }

      nav {
        background: var(--nav-bg);
        border-bottom: 1px solid var(--border);
        padding: 0.75rem 1.5rem;
      }

      nav a {
        color: var(--accent);
        text-decoration: none;
        font-weight: 500;
      }

      nav a:hover {
        text-decoration: underline;
      }

      main {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
      }

      h1, h2, h3, h4, h5, h6 {
        margin-top: 1.5em;
        margin-bottom: 0.5em;
        line-height: 1.3;
      }

      h1 { font-size: 2rem; }
      h2 { font-size: 1.5rem; }
      h3 { font-size: 1.25rem; }

      p {
        margin-bottom: 1em;
      }

      a {
        color: var(--accent);
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      mark {
        background-color: var(--mark-bg);
        color: var(--text);
        padding: 0.1em 0.2em;
        border-radius: 2px;
      }

      code {
        background: var(--code-bg);
        padding: 0.2em 0.4em;
        border-radius: 3px;
        font-size: 0.9em;
        font-family: 'JetBrains Mono', 'Fira Code', Consolas, monospace;
      }

      pre {
        background: var(--code-bg);
        padding: 1rem;
        border-radius: 6px;
        overflow-x: auto;
        margin: 1em 0;
      }

      pre code {
        background: none;
        padding: 0;
      }

      table {
        border-collapse: collapse;
        width: 100%;
        margin: 1em 0;
      }

      th, td {
        border: 1px solid var(--border);
        padding: 0.5rem 0.75rem;
        text-align: left;
      }

      th {
        background: var(--nav-bg);
        font-weight: 600;
      }

      ul, ol {
        padding-left: 1.5rem;
        margin-bottom: 1em;
      }

      li {
        margin-bottom: 0.25em;
      }

      hr {
        border: none;
        border-top: 1px solid var(--border);
        margin: 2em 0;
      }

      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin: 0.5rem 0;
      }

      .tag {
        background: var(--code-bg);
        color: var(--muted);
        padding: 0.2em 0.6em;
        border-radius: 9999px;
        font-size: 0.8rem;
        border: 1px solid var(--border);
      }

      .meta {
        color: var(--muted);
        font-size: 0.9rem;
        margin-bottom: 1.5rem;
      }
    </style>
  </head>
  <body>
    <nav>
      <a href={base + '/'}>← 回首頁</a>
    </nav>
    <main>
      <slot />
    </main>
  </body>
</html>
